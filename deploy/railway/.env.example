# ─────────────────────────────────────────────────────────────────────────────
# NocoBase LMS — Environment Variables
# Copy this file to .env (gitignored) for local development.
# Set these as Railway Variables in the Railway dashboard for production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
APP_PORT=13000

# Auto-enable the LMS + OIDC plugins on install/upgrade. These plugins live under
# packages/plugins/ and are auto-discovered, but listing them here enables them
# automatically (so you don't have to enable them by hand in the Plugin Manager).
APPEND_PRESET_BUILT_IN_PLUGINS=@nocobase/plugin-lms,@nocobase/plugin-auth-oidc

# Secret key for JWT signing and session encryption.
# Generate with: openssl rand -hex 32
APP_KEY=CHANGE_ME_use_openssl_rand_hex_32

# Public URL of your Railway deployment — used to build OIDC redirect URIs.
# Example: https://nocobase-lms.up.railway.app
APP_URL=https://your-app.up.railway.app

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# When using Railway's PostgreSQL plugin, set DATABASE_URL and leave the
# individual DB_* variables blank. NocoBase will parse DATABASE_URL automatically.
# Railway injects DATABASE_URL automatically when the Postgres plugin is linked.
DATABASE_URL=

# Alternatively, set individual connection parameters:
DB_DIALECT=postgres
DB_HOST=
DB_PORT=5432
DB_DATABASE=nocobase_lms
DB_USER=
DB_PASSWORD=
DB_SCHEMA=public

# ── Storage ───────────────────────────────────────────────────────────────────
# Path inside the container where uploads are stored.
# Must match the Railway volume mount path.
STORAGE_PATH=/app/storage

# ── Logging ───────────────────────────────────────────────────────────────────
LOGGER_LEVEL=info         # error | warn | info | debug | trace
LOGGER_TRANSPORT=console  # console | file | combined

# ── Microsoft Entra ID (Azure AD) SSO ────────────────────────────────────────
# These values are stored in the NocoBase authenticator record's options JSON,
# NOT as environment variables directly. However, recording them here makes
# Railway secret management easier — reference them when creating the
# authenticator record via the admin UI or seed script.
#
# Azure Portal → App registrations → your app → Overview
OIDC_CLIENT_ID=your-azure-app-client-id
# Azure Portal → App registrations → your app → Certificates & Secrets
OIDC_CLIENT_SECRET=your-azure-app-client-secret
# Azure Portal → Overview → Directory (tenant) ID
OIDC_TENANT_ID=your-azure-tenant-id
# Computed: https://login.microsoftonline.com/{OIDC_TENANT_ID}/v2.0
OIDC_ISSUER_URL=https://login.microsoftonline.com/your-tenant-id/v2.0
# Must match EXACTLY what you registered in the Azure app's Redirect URIs:
#   {APP_URL}/api/auth:redirect?authenticator=azure-ad
OIDC_REDIRECT_URI=https://your-app.up.railway.app/api/auth:redirect?authenticator=azure-ad

# ── Email / Notifications (optional) ─────────────────────────────────────────
# Used by plugin-workflow-mailer and plugin-notification-email.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="LMS Notifications <no-reply@example.com>"
